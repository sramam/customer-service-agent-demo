# OpenAI API key for the AI SDK
OPENAI_API_KEY=sk-...

# ElevenLabs text-to-speech (Remotion voice-over: pnpm voiceover:generate)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=3TStB8f3X3To0Uj5R7RK

# SQLite database path (used by prisma.config.ts, not schema.prisma in Prisma 7)
