# OpenAI API key for the AI SDK (required on Vercel for /api/chat, /api/agent-chat, /api/chat/classify)
OPENAI_API_KEY=sk-...

# ElevenLabs text-to-speech (Remotion voice-over: pnpm voiceover:generate)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=3TStB8f3X3To0Uj5R7RK

# SQLite — do NOT set DATABASE_URL on Vercel. Pasting local .env uses file:./dev.db and breaks serverless (SQLITE_CANTOPEN).
# Vercel: vercel-build creates prisma/dev.db; runtime copies to /tmp. Local dev: prisma.config.ts → prisma/dev.db.

# Landing page (/) walkthrough video — use YouTube embed for deploys (avoids shipping a large MP4).
# Leave unset to use public/f5-demo.mp4 locally after pnpm demo:publish-video.
NEXT_PUBLIC_DEMO_VIDEO_EMBED_URL=https://www.youtube.com/embed/PMbFpey0IRc
