# ElevenLabs text-to-speech (Remotion voice-over: pnpm voiceover:generate)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=3TStB8f3X3To0Uj5R7RK

# SQLite: local dev uses prisma/dev.db (see prisma.config.ts). Vercel POC: `vercel-build` creates a fresh
# migrated+seeded DB at build time; runtime copies it to /tmp so each deploy starts from that baseline (resets between deploys).

# Landing page (/) walkthrough video — use YouTube embed for deploys (avoids shipping a large MP4).
# Leave unset to use public/f5-demo.mp4 locally after pnpm demo:publish-video.
NEXT_PUBLIC_DEMO_VIDEO_EMBED_URL=https://www.youtube.com/embed/PMbFpey0IRc
