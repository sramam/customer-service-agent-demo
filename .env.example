# OpenAI API key for the AI SDK (required on Vercel for chat APIs)
OPENAI_API_KEY=sk-...

# Local Playwright / demo: skip DB-backed demo customer locks. Injected when Playwright starts
# `pnpm dev`. If you run `pnpm dev` yourself and run tests with server reuse, set this and restart.
# `pnpm showcase:replay-live` forces a dedicated server so you usually do not need this in .env.
# E2E_BYPASS_DEMO_CLAIM=1

# Playwright demo recording (WebM → Remotion): viewport + video size. Default 1920×1080 so split UI fits.
# PLAYWRIGHT_VIEWPORT_WIDTH=1920
# PLAYWRIGHT_VIEWPORT_HEIGHT=1080

# Live replay from export JSON (`pnpm showcase:replay-live replay/foo.json`) — keys are read from .env.
# Optional default path if you run `pnpm showcase:replay-live` with no argument:
# F5_REPLAY_EXPORT=./replay/david-replay1.json
# Declarative YAML/Markdown script (see `replay/showcase-example.yaml`):
# F5_REPLAY_SCRIPT=./replay/showcase-example.yaml
#
# Record script replay → WebM → ElevenLabs voiceover → optional MP4 (same beats as `pnpm showcase`):
#   pnpm showcase:script replay/showcase-example.yaml
#   pnpm showcase:script:full replay/showcase-example.yaml   # + seed + remotion render + public/f5-demo.mp4
#
# Freeform outline → AI writes YAML + per-beat voice copy → record + voice + MP4 by default:
#   pnpm showcase:outline replay/showcase-outline.example.txt
#   → remotion-out/f5-demo.mp4 and public/f5-demo.mp4
# Skip Remotion only: pnpm showcase:outline replay/x.txt -- --no-render
# Optional: SHOWCASE_OUTLINE_MODEL=gpt-4o-mini
# Optional: SHOWCASE_VOICE_NARRATIONS_JSON=./replay/.generated/voice-narrations.json (set by showcase:outline)
# Optional: run speaker-resolution before guidance (same as export:enrich-ai)
# F5_REPLAY_ENRICH=1
# Optional: model for replay guidance JSON (default gpt-4o-mini)
# SHOWCASE_REPLAY_MODEL=gpt-4o-mini

# Live replay — screenshot + vision drives customer chat from guidance (default on). Set to 0 for fallback opening line + heuristic escalation nudge only.
# F5_REPLAY_USE_VISION=1
# Vision model for decideCustomerReplayStepFromScreenshot (default gpt-4o)
# SHOWCASE_REPLAY_VISION_MODEL=gpt-4o
# Max vision decision steps before fallback escalate line (default 10)
# F5_REPLAY_VISION_MAX_STEPS=10

# Optional: Anthropic (Claude) when OpenAI fails — same `ANTHROPIC_FALLBACK_MODEL` everywhere:
# - Chat streaming (`/api/chat`, `/api/agent-chat`): before meaningful output only (see `ai-fallback-language-model.ts`).
# - Structured `generateObject` (replay guidance, vision decisions, export speaker resolve, showcase outline): one full retry.
# ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=

# Optional override for the primary OpenAI chat model (default gpt-5.4-mini).
# OPENAI_MODEL=gpt-5.4-mini

# ElevenLabs text-to-speech (Remotion voice-over: pnpm voiceover:generate)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=3TStB8f3X3To0Uj5R7RK

# Neon Postgres — pooled URL for the app (PrismaNeon adapter + Vercel).
# Example: postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Direct (non-pooler) URL for Prisma CLI: migrate, db push, introspection.
# Example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=

# Landing page (/) walkthrough — optional; production defaults to YouTube if unset.
NEXT_PUBLIC_DEMO_VIDEO_EMBED_URL=https://www.youtube.com/embed/PMbFpey0IRc

# PartyKit realtime (run `pnpm party:dev` in another terminal; default port 1999).
# Must match the secret in partykit.json `vars` (local) or PartyKit dashboard (deploy).
NEXT_PUBLIC_PARTYKIT_HOST=f5-realtime.sramam.partykit.dev
PARTYKIT_HOST=https://f5-realtime.sramam.partykit.dev
PARTYKIT_SECRET=local-dev-partykit-secret
